  "title_en": "Capital Flow Radar",
  "title_zh": "資金流向雷達",
  "method_en": "Five sequential layers: (L1) money map + (L2) indicator dictionary are a curated KB; (L3) live flow diagnosis is pure-quant from yfinance + FRED (keyless fredgraph.csv) + defillama; (L4) retail-vs-institution split + AI-market mapping and (L5) scenarios/triggers/falsification are synthesized by Claude on each refresh (rules fallback if no API key). Seed values let the dashboard render offline.",
  "method_zh": "五層循序：(L1)資金地圖 +(L2)指標字典為策展知識庫；(L3)即時流向診斷純量化,取自 yfinance + FRED(免 key 的 fredgraph.csv)+ defillama;(L4)散戶vs機構拆解 + AI 市場映射、(L5)情境/觸發/證偽,每次刷新由 Claude 綜合(無 API key 時走規則 fallback)。種子值讓儀表板可離線渲染。",

  "reservoirs": [
    {"id": "cash_mmf",   "name_en": "Cash / Money-market funds", "name_zh": "現金 / 貨幣市場基金", "size_en": "~$7.0T", "size_zh": "約 $7.0兆", "role_en": "Sidelined dry powder; the marginal fuel for risk assets.", "role_zh": "場邊乾火藥;風險資產的邊際燃料。", "group": "safe"},
    {"id": "bonds",      "name_en": "Government & credit bonds",  "name_zh": "公債與信用債",       "size_en": "~$28T UST", "size_zh": "約 $28兆 美債", "role_en": "Gravity for all risk assets; rates set the discount rate.", "role_zh": "所有風險資產的地心引力;利率決定折現率。", "group": "safe"},
    {"id": "gold",       "name_en": "Gold",                       "name_zh": "黃金",               "size_en": "~$18T mkt", "size_zh": "約 $18兆 市值", "role_en": "Safe haven & anti-fiat hedge; inverse to real yields.", "role_zh": "避險與抗法幣對沖;與實質利率反向。", "group": "safe"},
    {"id": "crypto",     "name_en": "Bitcoin & stablecoins",      "name_zh": "比特幣與穩定幣",     "size_en": "~$2T+$0.25T", "size_zh": "約 $2兆+$0.25兆", "role_en": "Risk-on liquidity sponge; stablecoin supply = crypto dry powder.", "role_zh": "risk-on 流動性海綿;穩定幣供應 = 加密乾火藥。", "group": "risk"},
    {"id": "equities",   "name_en": "Broad equity market",        "name_zh": "股票大盤",           "size_en": "~$55T US", "size_zh": "約 $55兆 美股", "role_en": "The main risk reservoir; breadth shows participation.", "role_zh": "主要風險蓄水池;廣度顯示參與度。", "group": "risk"},
    {"id": "ai_sector",  "name_en": "AI / semiconductor sector",  "name_zh": "AI / 半導體板塊",    "size_en": "concentrated", "size_zh": "高度集中", "role_en": "Where the AI thesis is priced; concentration & capex live here.", "role_zh": "AI 論點定價之處;集中度與 capex 在此。", "group": "risk"},
    {"id": "usd",        "name_en": "US dollar (DXY)",            "name_zh": "美元 (DXY)",         "size_en": "reserve FX", "size_zh": "儲備貨幣", "role_en": "Strong USD drains global liquidity, pressures risk & gold.", "role_zh": "美元走強抽乾全球流動性,壓制風險資產與黃金。", "group": "macro"}
  ],

  "tap": {
    "name_en": "Aggregate liquidity (the master tide)",
    "name_zh": "全市場流動性(主水龍頭)",
    "desc_en": "Net liquidity = Fed balance sheet − reverse repo − Treasury General Account. The tide that lifts or sinks every reservoir at once.",
    "desc_zh": "淨流動性 = Fed 資產負債表 − 逆回購 − 財政部帳戶(TGA)。同時抬升或下沉所有蓄水池的潮汐。"
  },

  "channels": [
    {"from": "cash_mmf", "to": "equities", "trigger_en": "Risk appetite rises / rate cuts", "trigger_zh": "風險偏好上升 / 降息", "direction": "risk_on"},
    {"from": "equities", "to": "cash_mmf", "trigger_en": "Rising MMF yields / fear spike", "trigger_zh": "貨幣基金殖利率升 / 恐慌", "direction": "risk_off"},
    {"from": "bonds",    "to": "gold",     "trigger_en": "Real yields fall / debasement fear", "trigger_zh": "實質利率下降 / 貶值疑慮", "direction": "hedge"},
    {"from": "gold",     "to": "bonds",    "trigger_en": "Real yields rise", "trigger_zh": "實質利率上升", "direction": "risk_off"},
    {"from": "cash_mmf", "to": "crypto",   "trigger_en": "Stablecoin supply expands / risk-on", "trigger_zh": "穩定幣供應擴張 / risk-on", "direction": "risk_on"},
    {"from": "equities", "to": "ai_sector","trigger_en": "AI thesis strength / capex acceleration", "trigger_zh": "AI 論點轉強 / capex 加速", "direction": "risk_on"},
    {"from": "ai_sector","to": "equities", "trigger_en": "Rotation out of AI / breadth broadens", "trigger_zh": "資金輪出 AI / 廣度擴散", "direction": "rotation"},
    {"from": "equities", "to": "usd",      "trigger_en": "Global risk-off / USD safe-haven bid", "trigger_zh": "全球 risk-off / 美元避險", "direction": "risk_off"}
