    {"id": "breadth", "name_en": "Breadth (RSP/SPX relative)", "name_zh": "市場廣度(等權/市值)", "unit": "rel%", "formula": "rsp_minus_spx", "rising_means": "risk_on", "rising_en": "Broadening participation (healthy)", "rising_zh": "參與度擴散(健康)", "falling_en": "Narrowing — concentration risk", "falling_zh": "收窄 — 集中度風險"},
