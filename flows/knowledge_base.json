    {"id": "rotation",     "name_en": "Rotation → AI corrects, index holds", "name_zh": "資金輪動 → AI 補跌、大盤撐住", "trigger_en": "AI_rel falling while RSP holds + breadth broadening", "trigger_zh": "AI 領先度下滑但 RSP 撐住 + 廣度擴散"},
