# Copy to .env (local) or set these as environment variables on your host.
# NEVER commit the real .env.

# Flask session signing key — generate a random one, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-hex-string

# Single shared login. Keep it neutral (no company name).
# Suggested: a generic role name + your own strong passphrase.
APP_USERNAME=analyst
APP_PASSWORD=change-me-strong-passphrase

# Token for the weekly external cron pinger that hits /cron/refresh?token=...
#   python -c "import secrets; print(secrets.token_urlsafe(24))"
REFRESH_TOKEN=change-me-random-token

# US Economic Monitor — weekly FRED data refresh (free key: https://fredaccount.stlouisfed.org/apikeys)
FRED_API_KEY=

# Optional — AI commentary / executive briefs (rules-based fallback if unset)
ANTHROPIC_API_KEY=

# Optional — AI Bubble refresh-button password (separate from site login; code default: aibubble2026)
AIBUBBLE_REFRESH_PASSWORD=

# Optional — Rival Radar refresh-button password (separate from site login; code default: rival2026)
RIVAL_REFRESH_PASSWORD=

# Optional — Capital Flow Radar refresh-button password (separate from site login; code default: capflow2026)
# When ANTHROPIC_API_KEY is set, a manual /flows refresh runs Claude Opus 4.8 for L4/L5 (one call/refresh).
CAPFLOW_REFRESH_PASSWORD=

# Optional — CapEx→Wafer Engine refresh + evidence-propose password (code default: cwengine2026)
# Refresh pulls live hyperscaler capex context; evidence-propose runs Claude Opus 4.8 when ANTHROPIC_API_KEY is set.
CWENGINE_REFRESH_PASSWORD=

# Supply-Chain Earnings Radar — live earnings calendar source (free key: https://finnhub.io/dashboard).
# Unset → the card serves the bundled snapshot only (no live refresh). US + ADR tickers covered on free tier.
FINNHUB_API_KEY=
# Optional — Earnings Radar refresh-button password (separate from site login; code default: earnings2026)
EARNINGS_REFRESH_PASSWORD=
# Optional — calendar look-ahead window in days (code default: 90)
EARNINGS_HORIZON_DAYS=90
